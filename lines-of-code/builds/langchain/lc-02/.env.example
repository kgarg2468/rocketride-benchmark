# Copy to .env and fill in. python-dotenv loads this automatically.

# Required.
OPENAI_API_KEY=sk-your-key-here

# Optional: enable LangSmith tracing (full runtime traces in the LangSmith UI).
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-langsmith-key
# LANGCHAIN_PROJECT=meeting-notes

# Optional overrides (defaults shown).
# MN_ORCHESTRATOR_MODEL=gpt-4.1
# MN_SUMMARY_MODEL=gpt-4.1
# MN_EMAIL_MODEL=gpt-4.1-mini
# MN_REQUEST_TIMEOUT=60
# MN_SDK_MAX_RETRIES=2
# MN_CHAIN_MAX_ATTEMPTS=3
# MN_TEMPERATURE=0.2
# MN_LOG_LEVEL=INFO
