# Copy to `.env` (auto-loaded via python-dotenv) or export these directly.

# REQUIRED — your OpenAI API key.
OPENAI_API_KEY=sk-your-key-here

# OPTIONAL — model overrides (defaults shown).
# MN_ORCHESTRATOR_MODEL=gpt-4.1
# MN_SUMMARY_MODEL=gpt-4.1
# MN_EMAIL_MODEL=gpt-4.1-mini

# OPTIONAL — runtime tuning (defaults shown).
# MN_LLM_TIMEOUT=45          # per-call timeout, seconds
# MN_LLM_MAX_RETRIES=3       # SDK-level retries
# MN_CHAIN_MAX_ATTEMPTS=2    # chain-level retry attempts
# MN_LLM_TEMPERATURE=0.0
# MN_LOG_LEVEL=INFO

# OPTIONAL — LangSmith tracing. Set both to export full traces.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-key-here
# LANGCHAIN_PROJECT=meeting-notes
