# Copy to .env and fill in.  Loaded automatically via python-dotenv.

# Required: OpenAI key used by both gpt-4.1 and gpt-4.1-mini calls.
OPENAI_API_KEY=sk-...

# --- Optional model/runtime overrides (sensible defaults baked in) ---
# ORCHESTRATOR_MODEL=gpt-4.1
# SUMMARIZER_MODEL=gpt-4.1
# EMAILER_MODEL=gpt-4.1-mini
# LLM_TIMEOUT_SECONDS=60        # per-call timeout
# LLM_MAX_RETRIES=4             # SDK-level retries (network/5xx/429)
# CHAIN_MAX_ATTEMPTS=3          # runnable-level retries (wraps the whole sub-chain)
# CHAIN_RETRY_WAIT=1.5          # base backoff seconds for runnable retries
# LOG_LEVEL=INFO

# --- Optional: LangSmith tracing/observability ---
# Set both to stream full traces to LangSmith in addition to local logging.
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_PROJECT=meeting-notes
