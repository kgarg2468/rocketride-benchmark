# Copy to `.env` and fill in. Loaded automatically by python-dotenv at startup.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Optional overrides (sane defaults baked into meeting_notes/config.py).
# ---------------------------------------------------------------------------

# Model selection (defaults shown).
# MEETING_NOTES_ORCHESTRATOR_MODEL=gpt-4.1
# MEETING_NOTES_SUMMARY_MODEL=gpt-4.1
# MEETING_NOTES_EMAIL_MODEL=gpt-4.1-mini

# Per-call timeout (seconds) and retry attempts.
# MEETING_NOTES_TIMEOUT=30
# MEETING_NOTES_MAX_RETRIES=3

# Log level for the console tracer: DEBUG | INFO | WARNING | ERROR
# MEETING_NOTES_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Optional: LangSmith tracing. If set, every Runnable/LLM call is exported to
# the LangSmith UI in addition to the built-in console tracer. No code change
# needed — LangChain picks these up from the environment automatically.
# ---------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=meeting-notes
