{
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": { "hideForm": true, "mode": "Source", "parameters": {}, "type": "webhook" }
    },
    {
      "id": "parse_1",
      "provider": "parse",
      "config": { "parameters": {} },
      "input": [{ "lane": "tags", "from": "webhook_1" }]
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": { "instructions": [], "parameters": {} },
      "input": [{ "lane": "text", "from": "parse_1" }]
    },
    {
      "id": "agent_rocketride_1",
      "provider": "agent_rocketride",
      "config": {
        "max_waves": 10,
        "parameters": {},
        "instructions": [
          "You process one document per turn. Each input on the questions lane is the full text of a single document.",
          "Step 1: extract the single most important named entity (organization, person, product, or project) from THIS document.",
          "Step 2: append that entity to your running list in keyed memory under the key 'entities'. First peek/get the current 'entities' list, then append the new entity, then put it back. Never overwrite or clear existing entries.",
          "Step 3: read the full 'entities' list back from memory and return it as a numbered list (oldest first, newest last) as your answer, with no other commentary.",
          "Your memory is private to this run. It contains only the entities from documents that THIS run has seen — never any other run's data."
        ]
      },
      "input": [{ "lane": "questions", "from": "question_1" }]
    },
    {
      "id": "llm_openai_1",
      "provider": "llm_openai",
      "config": {
        "profile": "gpt-4-1",
        "gpt-4-1": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
        "parameters": {}
      },
      "control": [{ "classType": "llm", "from": "agent_rocketride_1" }]
    },
    {
      "id": "memory_internal_1",
      "provider": "memory_internal",
      "config": { "type": "memory_internal" },
      "control": [{ "classType": "memory", "from": "agent_rocketride_1" }]
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "config": { "laneName": "answers" },
      "input": [{ "lane": "answers", "from": "agent_rocketride_1" }]
    }
  ],
  "project_id": "7a1c9d4b-2e63-4f85-9c07-3b4d5e6f7a02",
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "version": 1
}
